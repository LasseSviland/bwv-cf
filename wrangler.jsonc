{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "better-wines-viner",
  "main": "./apps/worker/src/index.ts",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": false,
  "secrets": {
    "required": ["API_KEY", "VINMONOPOLET_OPEN_API_KEY", "VINMONOPOLET_RESTRICTED_API_KEY"],
  },
  "placement": {
    "mode": "smart",
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./apps/web/dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"],
  },
  "r2_buckets": [
    {
      "binding": "DATA_BUCKET",
      "bucket_name": "better-wines-viner-data",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "SYNC_QUEUE",
        "queue": "better-wines-viner-sync",
      },
    ],
    "consumers": [
      {
        "queue": "better-wines-viner-sync",
        "max_batch_size": 1,
        "max_batch_timeout": 1,
        "max_retries": 5,
        "retry_delay": 30,
        "dead_letter_queue": "better-wines-viner-sync-dlq",
        "max_concurrency": 1,
      },
    ],
  },
  "triggers": {
    "crons": ["15 7 * * *"],
  },
  "limits": {
    "cpu_ms": 300000,
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
