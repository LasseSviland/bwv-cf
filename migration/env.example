# Phase 1: legacy MySQL (choose DATABASE_URL or the individual DB fields)
MIGRATION_DATABASE_URL=mysql://user:password@host:3306/database
# MIGRATION_DB_HOST=localhost
# MIGRATION_DB_PORT=3306
# MIGRATION_DB_USER=user
# MIGRATION_DB_PASSWORD=password
# MIGRATION_DB_NAME=database
# MIGRATION_DB_SSL=false

# Alternatively, point directly at the old Spring Boot settings file.
# MIGRATION_LEGACY_PROPERTIES=/absolute/path/to/application.properties

# Phase 2: Cloudflare R2 S3 credentials scoped to this bucket.
CLOUDFLARE_ACCOUNT_ID=your-account-id
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
# AWS_SESSION_TOKEN=optional-temporary-session-token
MIGRATION_R2_BUCKET=better-wines-viner-data
# MIGRATION_R2_JURISDICTION=default
# MIGRATION_R2_ENDPOINT=https://account-id.r2.cloudflarestorage.com

# Wrangler OAuth fallback (uses the existing `wrangler login` session).
# MIGRATION_STATUS_URL=https://better-wines-viner.sviland.workers.dev/api/v1/status
# MIGRATION_API_KEY=the-worker-api-key
